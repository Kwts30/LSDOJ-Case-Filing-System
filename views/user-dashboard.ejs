<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Department of Justice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body>
    <%- include('partials/header') %>

    <div class="main-layout">
        <%- include('partials/sidebar') %>

        <main class="main-content">
            <div class="container">
                <!-- Page Header -->
                <div class="page-header">
                    <div class="page-header-text">
                        <h1>My Dashboard</h1>
                        <p>Your personal document activity overview.</p>
                    </div>
                </div>

                <!-- Stat Cards -->
                <div class="grid grid-3 mb-xl">
                    <div class="card stat-card">
                        <div class="card-body">
                            <span class="material-icons stat-icon stat-icon--secondary">description</span>
                            <span class="stat-value"><%= stats.totalDocuments %></span>
                            <span class="stat-label">Total Documents</span>
                        </div>
                    </div>

                    <div class="card stat-card">
                        <div class="card-body">
                            <span class="material-icons stat-icon stat-icon--success">today</span>
                            <span class="stat-value"><%= stats.documentsToday %></span>
                            <span class="stat-label">Created Today</span>
                        </div>
                    </div>

                    <div class="card stat-card">
                        <div class="card-body">
                            <span class="material-icons stat-icon stat-icon--warning">category</span>
                            <span class="stat-value"><%= stats.documentTypes %></span>
                            <span class="stat-label">Document Types Used</span>
                        </div>
                    </div>
                </div>

                <!-- Detail Cards -->
                <div class="grid grid-2">
                    <!-- By Document Type -->
                    <div class="card">
                        <div class="card-header card-header-row">
                            <span class="material-icons">pie_chart</span>
                            <h3>By Document Type</h3>
                        </div>
                        <div class="card-body">
                            <% if (documentsByType && documentsByType.length) { %>
                                <table class="table-clean">
                                    <tbody>
                                    <% documentsByType.forEach(item => { %>
                                        <tr>
                                            <td><%= item._id || 'Unknown' %></td>
                                            <td class="text-right"><strong><%= item.count %></strong></td>
                                        </tr>
                                    <% }) %>
                                    </tbody>
                                </table>
                            <% } else { %>
                                <p class="text-tertiary text-center">No document data yet.</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- Recent Documents -->
                    <div class="card">
                        <div class="card-header card-header-row">
                            <span class="material-icons">history</span>
                            <h3>Recent Documents</h3>
                        </div>
                        <div class="card-body">
                            <% if (recentDocuments && recentDocuments.length) { %>
                                <table class="table-clean">
                                    <tbody>
                                    <% recentDocuments.forEach(doc => { %>
                                        <tr>
                                            <td>
                                                <div class="font-semibold">
                                                    <%= doc.doc_type || doc.documentType || 'Document' %>
                                                </div>
                                                <div class="text-tertiary text-xs">
                                                    <%= new Date(doc.created_at || doc.createdAt || Date.now()).toLocaleString() %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                    </tbody>
                                </table>
                            <% } else { %>
                                <p class="text-tertiary text-center">No recent documents.</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
