<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Dashboard">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
    <style>
        /* ── Dashboard Specific ── */
        .user-stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 1.75rem; }
        @media (max-width: 900px) { .user-stat-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 600px) { .user-stat-grid { grid-template-columns: 1fr; } }

        .stat-card-adv {
            background: var(--color-bg-primary); border: 1px solid var(--color-border);
            border-radius: 14px; padding: 1.5rem; display: flex; align-items: center; gap: 1.25rem;
            transition: transform 0.18s ease, box-shadow 0.18s ease; position: relative; overflow: hidden;
        }
        .stat-card-adv:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
        .stat-card-adv::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; border-radius: 14px 0 0 14px; }
        
        .stat-card-adv.blue::before   { background: #3b82f6; }
        .stat-card-adv.amber::before  { background: #f59e0b; }
        .stat-card-adv.green::before  { background: #10b981; }

        .stat-icon-wrap { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .stat-icon-wrap.blue  { background: rgba(59,130,246,.13); color: #3b82f6; }
        .stat-icon-wrap.amber { background: rgba(245,158,11,.13); color: #f59e0b; }
        .stat-icon-wrap.green { background: rgba(16,185,129,.13); color: #10b981; }
        .stat-icon-wrap .material-icons { font-size: 1.6rem; }

        .stat-meta { flex: 1; min-width: 0; }
        .stat-number { font-size: 2rem; font-weight: 700; line-height: 1; color: var(--color-text-primary); letter-spacing: -0.03em; }
        .stat-desc { font-size: 0.8rem; color: var(--color-text-tertiary); margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }

        .user-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.75rem; }
        @media (max-width: 860px) { .user-grid-2 { grid-template-columns: 1fr; } }

        .panel { background: var(--color-bg-primary); border: 1px solid var(--color-border); border-radius: 14px; overflow: hidden; }
        .panel-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-border); background: var(--color-bg-secondary); }
        .panel-title { display: flex; align-items: center; gap: 0.6rem; font-weight: 700; font-size: 0.9rem; color: var(--color-text-primary); }
        .panel-title .material-icons { font-size: 1.1rem; color: var(--color-secondary); }
        .panel-body { max-height: 340px; overflow-y: auto; }

        .list-row { display: flex; align-items: center; gap: 0.85rem; padding: 0.875rem 1.25rem; border-bottom: 1px solid var(--color-border); transition: background 0.12s; }
        .list-row:last-child { border-bottom: none; }
        .list-row:hover { background: var(--color-bg-secondary); }
        .list-icon-wrap { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: var(--color-bg-secondary); }
        .list-icon-wrap .material-icons { font-size: 1rem; color: var(--color-text-secondary); }
        
        .list-meta { flex: 1; min-width: 0; }
        .list-primary { font-size: 0.85rem; font-weight: 600; color: var(--color-text-primary); }
        .list-secondary { font-size: 0.75rem; color: var(--color-text-tertiary); margin-top: 2px; }
        .list-right { font-weight: 700; color: var(--color-text-primary); font-size: 0.9rem; }

        .doc-badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 99px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; }
        .doc-badge.birth      { background: rgba(59,130,246,.15); color: #3b82f6; }
        .doc-badge.marriage   { background: rgba(244,63,94,.15);  color: #f43f5e; }
        .doc-badge.business   { background: rgba(245,158,11,.15); color: #d97706; }
        .doc-badge.origland   { background: rgba(16,185,129,.15); color: #059669; }
        .doc-badge.transfer   { background: rgba(139,92,246,.15); color: #7c3aed; }
        .doc-badge.default    { background: var(--color-bg-tertiary); color: var(--color-text-secondary); }

        .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2.5rem 1rem; gap: 0.5rem; }
        .empty-state .material-icons { font-size: 2.5rem; color: var(--color-text-tertiary); opacity: 0.4; }
        .empty-state p { font-size: 0.82rem; color: var(--color-text-tertiary); margin: 0; }
        
        .page-header-flex { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 1rem; }
        .page-title { font-size: 1.6rem; font-weight: 800; margin: 0; color: var(--color-text-primary); display: flex; align-items: center; gap: 0.5rem; }
        .page-title .material-icons { font-size: 1.8rem; color: var(--color-secondary); }
        .page-sub { margin: 0.25rem 0 0; font-size: 0.85rem; color: var(--color-text-tertiary); }
    </style>
</head>
<body class="app-layout">
    <%- include('partials/header') %>
    <%- include('partials/sidebar') %>

    <main class="main-content">
        <div class="container" style="max-width: 1400px; padding: 1.5rem;">
            
            <!-- Page Header -->
            <div class="page-header-flex">
                <div>
                    <h1 class="page-title">
                        <span class="material-icons">dashboard</span>
                        Dashboard
                    </h1>
                    <p class="page-sub">Overview of your activity and departmental statistics</p>
                </div>
                <% if (department === 'LSPD') { %>
                <a href="/filings/new" class="btn btn-primary" style="display:flex; align-items:center; gap:0.4rem; font-size:0.85rem;">
                    <span class="material-icons" style="font-size:1.1rem;">add_circle</span>
                    File New Request
                </a>
                <% } else if (department === 'DA' || department === 'DOJ') { %>
                <a href="/da-review" class="btn btn-primary" style="display:flex; align-items:center; gap:0.4rem; font-size:0.85rem;">
                    <span class="material-icons" style="font-size:1.1rem;">rate_review</span>
                    Review Queue
                </a>
                <% } %>
            </div>

            <!-- ═══ MY STAT CARDS ═══ -->
            <h2 style="font-size: 1.1rem; margin-bottom: 1rem; color: var(--color-text-secondary);">My Statistics (<%= department %>)</h2>
            <div class="user-stat-grid">
                <div class="stat-card-adv blue">
                    <div class="stat-icon-wrap blue">
                        <span class="material-icons"><%= department === 'LSPD' ? 'folder' : 'rate_review' %></span>
                    </div>
                    <div class="stat-meta">
                        <div class="stat-number"><%= personalStats.total %></div>
                        <div class="stat-desc">Total <%= (department === 'DA' || department === 'DOJ') ? 'Assigned' : 'Filings' %></div>
                    </div>
                </div>
                <div class="stat-card-adv amber">
                    <div class="stat-icon-wrap amber">
                        <span class="material-icons">hourglass_top</span>
                    </div>
                    <div class="stat-meta">
                        <div class="stat-number"><%= personalStats.pending %></div>
                        <div class="stat-desc">Pending Review</div>
                    </div>
                </div>
                <div class="stat-card-adv green">
                    <div class="stat-icon-wrap green">
                        <span class="material-icons">task_alt</span>
                    </div>
                    <div class="stat-meta">
                        <div class="stat-number"><%= personalStats.completed %></div>
                        <div class="stat-desc">Completed</div>
                    </div>
                </div>
            </div>

            <!-- ═══ DEPARTMENT STAT CARDS ═══ -->
            <h2 style="font-size: 1.1rem; margin-top: 2rem; margin-bottom: 1rem; color: var(--color-text-secondary);">Department Overview</h2>
            <div class="user-stat-grid">
                <div class="stat-card-adv blue">
                    <div class="stat-icon-wrap blue">
                        <span class="material-icons">domain</span>
                    </div>
                    <div class="stat-meta">
                        <div class="stat-number"><%= deptStats.total %></div>
                        <div class="stat-desc">Total Records</div>
                    </div>
                </div>
                <div class="stat-card-adv amber">
                    <div class="stat-icon-wrap amber">
                        <span class="material-icons">pending_actions</span>
                    </div>
                    <div class="stat-meta">
                        <div class="stat-number"><%= deptStats.pending %></div>
                        <div class="stat-desc">In Progress</div>
                    </div>
                </div>
                <div class="stat-card-adv green">
                    <div class="stat-icon-wrap green">
                        <span class="material-icons">check_circle</span>
                    </div>
                    <div class="stat-meta">
                        <div class="stat-number"><%= deptStats.completed %></div>
                        <div class="stat-desc">Closed / Filed</div>
                    </div>
                </div>
            </div>

            <!-- ═══ DETAIL CARDS ═══ -->
            <div class="user-grid-2">
                
                <!-- By Document Type -->
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">
                            <span class="material-icons">pie_chart</span>
                            <%= (department === 'DA' || department === 'DOJ') ? 'My Reviews' : 'My Filings' %> By Type
                        </div>
                    </div>
                    <div class="panel-body">
                        <% if (documentsByType && documentsByType.length) { %>
                            <% documentsByType.forEach(item => { 
                                const tLabel = Object.values(FILING_TYPES).flat().find(t => t.value === item._id)?.label || item._id;
                            %>
                            <div class="list-row">
                                <div class="list-icon-wrap">
                                    <span class="material-icons">description</span>
                                </div>
                                <div class="list-meta">
                                    <div class="list-primary"><%= tLabel %></div>
                                    <div class="list-secondary">Type: <%= item._id %></div>
                                </div>
                                <div class="list-right">
                                    <%= item.count %>
                                </div>
                            </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <span class="material-icons">pie_chart_outline</span>
                                <p>No data yet</p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Recent Documents -->
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">
                            <span class="material-icons">history</span>
                            Recent Activity
                        </div>
                    </div>
                    <div class="panel-body">
                        <% if (recentDocuments && recentDocuments.length) { %>
                            <% recentDocuments.forEach(doc => { 
                                const tLabel = Object.values(FILING_TYPES).flat().find(t => t.value === doc.filing_type)?.label || doc.filing_type;
                                const dateStr = (doc.updated_at || doc.created_at) 
                                    ? new Date(doc.updated_at || doc.created_at).toLocaleString('en-US', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' })
                                    : '—';
                                const badgeColor = (doc.status === 'filed' || doc.status === 'dismissed') ? 'origland' : (doc.status === 'needs_revision' ? 'marriage' : 'birth');
                            %>
                            <div class="list-row">
                                <div class="list-icon-wrap">
                                    <span class="material-icons">gavel</span>
                                </div>
                                <div class="list-meta">
                                    <div class="list-primary">
                                        <a href="<%= (department === 'DA' || department === 'DOJ') ? '/da-review/' + doc.filing_number : '/filings/' + doc.filing_number %>" style="color: var(--color-primary); text-decoration: none;">
                                            <%= doc.filing_number %> - <%= doc.accused_name || 'Unknown' %>
                                        </a>
                                    </div>
                                    <div class="list-secondary"><%= dateStr %> • Status: <%= doc.status.replace(/_/g, ' ') %></div>
                                </div>
                                <div>
                                    <span class="doc-badge <%= badgeColor %>"><%= tLabel %></span>
                                </div>
                            </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <span class="material-icons">history_toggle_off</span>
                                <p>No recent activity</p>
                            </div>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
