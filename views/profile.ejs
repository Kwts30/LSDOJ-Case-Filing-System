<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile — Department of Justice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
    <style>
        .profile-header {
            display: flex;
            align-items: center;
            gap: var(--space-lg);
            padding: var(--space-3xl) var(--space-lg);
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
            color: white;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        }

        .profile-avatar {
            font-size: 4rem !important;
            color: var(--color-secondary) !important;
            background: rgba(255, 255, 255, 0.1);
            padding: var(--space-lg);
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            width: 120px;
            height: 120px;
            flex-shrink: 0;
        }

        .profile-header-info h1 {
            color: white;
            margin: 0 0 var(--space-sm) 0;
        }

        .profile-header-info p {
            color: rgba(255, 255, 255, 0.9);
            margin: 0 0 var(--space-md) 0;
            font-size: var(--font-size-sm);
        }

        .profile-actions {
            display: flex;
            gap: var(--space-sm);
            margin-top: var(--space-md);
        }

        .profile-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: var(--space-lg);
            margin-top: var(--space-lg);
        }

        .profile-card {
            background: var(--color-bg-primary);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: var(--space-lg);
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
        }

        .profile-card h3 {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            color: var(--color-primary);
            margin: 0 0 var(--space-md) 0;
            font-size: var(--font-size-lg);
            padding-bottom: var(--space-md);
            border-bottom: 2px solid var(--color-border);
        }

        .profile-card .material-icons {
            font-size: 1.5rem;
        }

        .profile-field {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .profile-field-label {
            font-size: var(--font-size-sm);
            font-weight: var(--font-weight-semibold);
            color: var(--color-text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .profile-field-value {
            font-size: var(--font-size-base);
            font-weight: var(--font-weight-medium);
            color: var(--color-text-primary);
        }

        .profile-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-lg);
        }

        .btn-edit {
            background: #0d2c53;
            color: white;
            border: none;
            transition: all var(--transition-fast);
        }

        .btn-edit:hover {
            background: #174a8c;
            box-shadow: 0 2px 8px rgba(13, 44, 83, 0.3);
        }

        .profile-tabs {
            display: flex;
            gap: var(--space-md);
            border-bottom: 1px solid var(--color-border);
            margin-bottom: var(--space-lg);
        }

        .profile-tab {
            padding: var(--space-md) 0;
            border: none;
            background: none;
            cursor: pointer;
            font-weight: var(--font-weight-semibold);
            color: var(--color-text-secondary);
            border-bottom: 3px solid transparent;
            transition: all var(--transition-fast);
        }

        .profile-tab.active {
            color: var(--color-primary);
            border-bottom-color: var(--color-primary);
        }

        .modal-profile {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: var(--space-md);
        }

        .modal-profile.active {
            display: flex;
        }

        .modal-content {
            background: var(--color-bg-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-2xl);
            max-width: 480px;
            width: 100%;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            border: 1px solid var(--color-border);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: var(--space-xl);
            border-bottom: 2px solid var(--color-border);
            padding-bottom: var(--space-lg);
        }

        .modal-header h2 {
            margin: 0;
            color: var(--color-primary);
            font-size: var(--font-size-2xl);
        }

        .modal-close {
            background: none;
            border: none;
            font-size: 1.75rem;
            cursor: pointer;
            color: var(--color-text-secondary);
            padding: 0;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition-fast);
        }

        .modal-close:hover {
            color: var(--color-text-primary);
            transform: scale(1.1);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-bottom: var(--space-lg);
        }

        .form-group label {
            font-weight: var(--font-weight-semibold);
            color: var(--color-text-primary);
            font-size: var(--font-size-sm);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-group input,
        .form-group select {
            padding: 0.875rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            font-size: var(--font-size-base);
            background: var(--color-bg-secondary);
            color: var(--color-text-primary);
            font-family: var(--font-family-base);
            transition: all var(--transition-fast);
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px var(--color-primary-light);
            background: var(--color-bg-primary);
        }

        .modal-actions {
            display: flex;
            gap: var(--space-md);
            margin-top: var(--space-2xl);
            border-top: 2px solid var(--color-border);
            padding-top: var(--space-xl);
            justify-content: flex-end;
        }

        .modal-actions .btn {
            flex: 1;
            padding: 0.875rem 1.5rem;
            font-size: var(--font-size-base);
            font-weight: var(--font-weight-semibold);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .modal-actions .btn-primary,
        .modal-actions .btn-outline {
            flex: 1;
        }

        .stat-box {
            text-align: center;
            padding: var(--space-lg);
            background: var(--color-bg-secondary);
            border-radius: var(--radius-md);
        }

        .stat-number {
            font-size: 1.75rem;
            font-weight: var(--font-weight-bold);
            color: var(--color-primary);
        }

        .stat-label {
            font-size: var(--font-size-sm);
            color: var(--color-text-secondary);
            margin-top: 0.5rem;
        }

        .alert {
            padding: var(--space-md) var(--space-lg);
            border-radius: var(--radius-md);
            margin-bottom: var(--space-lg);
            display: flex;
            align-items: center;
            gap: var(--space-md);
        }

        .alert.success {
            background: rgba(34, 197, 94, 0.1);
            color: var(--color-success);
            border: 1px solid var(--color-success);
        }

        .alert.error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--color-error);
            border: 1px solid var(--color-error);
        }

        .alert .material-icons {
            font-size: 1.25rem;
        }

        @media (max-width: 768px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
            }
            .profile-row {
                grid-template-columns: 1fr;
            }
            .modal-content {
                width: 100%;
                max-width: 100%;
                max-height: 90vh;
                padding: var(--space-lg);
                margin: 0 var(--space-md);
                border-radius: var(--radius-lg);
            }
            .modal-profile {
                padding: 0;
            }
        }

        /* ===== DARK MODE - Easy on the eyes ===== */
        :root[data-theme="dark"] .profile-header {
            background: linear-gradient(135deg, #2d2416 0%, #1f1810 100%);
            color: #f3f4f6;
        }

        :root[data-theme="dark"] .profile-avatar {
            background: rgba(255, 255, 255, 0.05);
            color: #b3dff5 !important;
        }

        :root[data-theme="dark"] .profile-header-info p {
            color: rgba(255, 255, 255, 0.7);
        }

        :root[data-theme="dark"] .profile-card h3 {
            color: #d9b37a;
        }

        :root[data-theme="dark"] .alert {
            background: rgba(51, 65, 85, 0.5);
            border: 1px solid rgba(100, 120, 140, 0.3);
        }

        :root[data-theme="dark"] .alert.success {
            background: rgba(16, 185, 129, 0.1);
            color: #86efac;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        :root[data-theme="dark"] .alert.error {
            background: rgba(239, 68, 68, 0.1);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        :root[data-theme="dark"] .btn-edit {
            background: #4a90e2;
            color: white;
            border: none;
        }

        :root[data-theme="dark"] .btn-edit:hover {
            background: #357abd;
            box-shadow: 0 2px 8px rgba(74, 144, 226, 0.3);
        }

        :root[data-theme="dark"] .modal-content {
            background: #1a1f2e;
            border: 1px solid #2d3442;
        }

        :root[data-theme="dark"] .modal-header {
            border-bottom-color: #2d3442;
            color: #e5e7eb;
        }

        :root[data-theme="dark"] .modal-header h2 {
            color: #d9b37a;
        }

        :root[data-theme="dark"] .form-group label {
            color: #b8bcc5;
        }

        :root[data-theme="dark"] .form-group input,
        :root[data-theme="dark"] .form-group select {
            background: #10141e;
            border-color: #2d3442;
            color: #e5e7eb;
        }

        :root[data-theme="dark"] .form-group input:focus,
        :root[data-theme="dark"] .form-group select:focus {
            border-color: #c9a36a;
            box-shadow: 0 0 0 3px rgba(201, 163, 106, 0.1);
            background: #1a1f2e;
        }

        :root[data-theme="dark"] .modal-actions {
            border-top-color: #2d3442;
        }

        :root[data-theme="dark"] .modal-actions .btn {
            background: #357abd;
            color: white;
        }

        :root[data-theme="dark"] .modal-actions .btn:hover {
            background: #2a5a9e;
        }

        :root[data-theme="dark"] .modal-actions .btn-outline {
            background: transparent;
            border: 1px solid #2d3442;
            color: #b8bcc5;
        }

        :root[data-theme="dark"] .modal-actions .btn-outline:hover {
            background: #0f1319;
            border-color: #3d4a5c;
            color: #e5e7eb;
        }

        #alert-message {
            padding: var(--space-md) var(--space-lg);
            border-radius: var(--radius-md);
            margin-bottom: var(--space-lg);
            display: flex;
            align-items: center;
            gap: var(--space-md);
            font-size: var(--font-size-sm);
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>

    <div class="main-layout">
        <%- include('partials/sidebar') %>
        <main class="main-content">
            <div class="container">
                <!-- Profile Header -->
                <div class="card" style="margin-bottom: var(--space-lg);">
                    <div class="profile-header">
                        <span class="material-icons profile-avatar">account_circle</span>
                        <div class="profile-header-info" style="flex: 1;">
                            <h1><%= user.firstName %> <%= user.lastName %></h1>
                            <p><%= user.email %></p>
                            <span class="badge badge-<%= user.role === 'admin' ? 'error' : 'success' %>">
                                <%= user.role === 'admin' ? 'Administrator' : 'User' %>
                            </span>
                            <div class="profile-actions">
                                <button id="edit-profile-btn" class="btn btn-edit" type="button">
                                    <span class="material-icons">edit</span>
                                    Edit Profile
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Profile Grid -->
                <div class="profile-grid">
                    <!-- Account Information -->
                    <div class="profile-card">
                        <h3>
                            <span class="material-icons">info</span>
                            Account Information
                        </h3>
                        <div class="profile-field">
                            <span class="profile-field-label">Username</span>
                            <span class="profile-field-value"><%= user.username %></span>
                        </div>
                        <div class="profile-field">
                            <span class="profile-field-label">Email</span>
                            <span class="profile-field-value"><%= user.email %></span>
                        </div>
                        <div class="profile-field">
                            <span class="profile-field-label">Account Status</span>
                            <span class="profile-field-value">
                                <span class="material-icons" style="font-size: 1rem; color: var(--color-success); vertical-align: middle;">check_circle</span>
                                Active
                            </span>
                        </div>
                    </div>

                    <!-- Role & Permissions -->
                    <div class="profile-card">
                        <h3>
                            <span class="material-icons">security</span>
                            Role & Permissions
                        </h3>
                        <div class="profile-field">
                            <span class="profile-field-label">User Role</span>
                            <span class="profile-field-value">
                                <span class="material-icons" style="font-size: 1rem; vertical-align: middle;">
                                    <%= user.role === 'admin' ? 'shield_admin' : 'person' %>
                                </span>
                                <%= user.role === 'admin' ? 'Administrator' : 'Standard User' %>
                            </span>
                        </div>
                        <div class="profile-field">
                            <span class="profile-field-label">Access Level</span>
                            <span class="profile-field-value">
                                <%= user.role === 'admin' ? 'Full System Access' : 'User Access' %>
                            </span>
                        </div>
                    </div>

                </div>

                <!-- Additional Information -->
                <div class="card" style="margin-top: var(--space-lg); padding: var(--space-lg);">
                    <h2 style="margin-top: 0; margin-bottom: var(--space-lg);">Additional Information</h2>
                    <div class="profile-row">
                        <div class="profile-field">
                            <span class="profile-field-label">Department</span>
                            <span class="profile-field-value"><%= user.department || 'Not assigned' %></span>
                        </div>
                        <div class="profile-field">
                            <span class="profile-field-label">Member Since</span>
                            <span class="profile-field-value">2024</span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div style="display: flex; gap: var(--space-md); margin-top: var(--space-lg);">
                    <a href="/" class="btn btn-outline" style="flex: 1; text-align: center;">
                        <span class="material-icons">arrow_back</span>
                        Back to Dashboard
                    </a>
                    <form action="/auth/logout" method="POST" style="flex: 1;">
                        <button type="submit" class="btn btn-error" style="width: 100%;">
                            <span class="material-icons">logout</span>
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <!-- Edit Profile Modal -->
    <div class="modal-profile" id="edit-profile-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Edit Profile</h2>
                <button type="button" class="modal-close" id="close-modal">&times;</button>
            </div>

            <div id="alert-message" style="display: none;"></div>

            <form id="edit-profile-form">
                <div class="form-group">
                    <label for="firstName">First Name</label>
                    <input type="text" id="firstName" name="firstName" value="<%= user.firstName %>" required>
                </div>

                <div class="form-group">
                    <label for="lastName">Last Name</label>
                    <input type="text" id="lastName" name="lastName" value="<%= user.lastName %>" required>
                </div>

                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" value="<%= user.email %>" required>
                </div>

                <div class="form-group">
                    <label for="department">Department</label>
                    <input type="text" id="department" name="department" value="<%= user.department || '' %>" placeholder="Enter department">
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn btn-outline" id="cancel-btn">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="material-icons">save</span>
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Modal functionality
        const modal = document.getElementById('edit-profile-modal');
        const editBtn = document.getElementById('edit-profile-btn');
        const closeBtn = document.getElementById('close-modal');
        const cancelBtn = document.getElementById('cancel-btn');
        const form = document.getElementById('edit-profile-form');
        const alertDiv = document.getElementById('alert-message');

        editBtn.addEventListener('click', () => {
            modal.classList.add('active');
        });

        closeBtn.addEventListener('click', () => {
            modal.classList.remove('active');
        });

        cancelBtn.addEventListener('click', () => {
            modal.classList.remove('active');
        });

        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.remove('active');
            }
        });

        // Form submission
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            alertDiv.style.display = 'none';

            const formData = {
                firstName: document.getElementById('firstName').value,
                lastName: document.getElementById('lastName').value,
                email: document.getElementById('email').value,
                department: document.getElementById('department').value
            };

            try {
                const response = await fetch('/auth/profile/update', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(formData)
                });

                // Check if response is ok first
                if (!response.ok) {
                    const contentType = response.headers.get('content-type');
                    let errorMessage = 'Failed to update profile';
                    
                    if (contentType && contentType.includes('application/json')) {
                        const data = await response.json();
                        errorMessage = data.error || errorMessage;
                    } else {
                        errorMessage = `Server error: ${response.status} ${response.statusText}`;
                    }
                    
                    throw new Error(errorMessage);
                }

                const data = await response.json();

                if (data.success) {
                    alertDiv.className = 'alert success';
                    alertDiv.innerHTML = '<span class="material-icons">check_circle</span><span>' + (data.message || 'Profile updated successfully! Reloading...') + '</span>';
                    alertDiv.style.display = 'flex';
                    
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    throw new Error(data.error || 'Failed to update profile');
                }
            } catch (error) {
                console.error('Profile update error:', error);
                alertDiv.className = 'alert error';
                alertDiv.innerHTML = '<span class="material-icons">error</span><span>' + (error.message || 'An error occurred while updating your profile') + '</span>';
                alertDiv.style.display = 'flex';
            }
        });
    </script>

                    <!-- Admin Quick Links -->
                    <% if (user.role === 'admin') { %>
                        <div class="alert alert-info" style="margin:0;border-radius:0;border-left:none;border-right:none;border-bottom:none;">
                            <span class="material-icons">shield</span>
                            <div>
                                <p style="margin:0 0 var(--space-md) 0;font-weight:var(--font-weight-semibold);">Administrator Options</p>
                                <div class="grid grid-2">
                                    <a href="/admin" class="btn btn-secondary">
                                        <span class="material-icons">dashboard</span> Dashboard
                                    </a>
                                    <a href="/admin/users" class="btn btn-secondary">
                                        <span class="material-icons">group</span> Users
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
