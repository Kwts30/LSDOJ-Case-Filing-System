<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — DOJ System</title>
    <meta name="description" content="Department of Justice Auto-Fillup System login">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body class="login-page">
    <button type="button" class="btn btn-outline theme-toggle-btn" title="Toggle Theme" style="position: absolute; top: var(--space-lg); right: var(--space-lg); background: var(--color-bg-primary); border-color: transparent;">
        <span class="material-icons theme-toggle-icon">light_mode</span>
    </button>
    <div class="login-container">
        <div class="login-seal-wrapper">
            <img src="/assets/doj.png" alt="DOJ Seal" class="login-seal">
        </div>
        <div class="login-header">
            <h1>Department of Justice System</h1>
            <p>Auto-Fill & Issuance Tracking</p>
        </div>

        <div class="login-body">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error">
                    <span class="material-icons">error</span>
                    <span><%= error %></span>
                </div>
            <% } %>

            <form method="POST" action="/auth/login">
                <div class="form-group custom-login-group">
                    <label for="username">Username</label>
                    <input
                        type="text"
                        id="username"
                        name="username"
                        placeholder="Enter your username"
                        required
                        autofocus
                        class="custom-login-input"
                    >
                </div>

                <div class="form-group custom-login-group">
                    <label for="password">Password</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        placeholder="Enter your password"
                        required
                        class="custom-login-input"
                    >
                </div>

                <button type="submit" class="login-submit-btn">
                    Sign In
                </button>
            </form>
            
            <div class="login-forgot">
                <a href="#">Forgot Password?</a>
            </div>
        </div>

        <div class="login-footer">
            &copy; 2026 Department of Justice. All rights reserved.
        </div>
    </div>
</body>
</html>
