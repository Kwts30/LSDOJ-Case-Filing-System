<!-- Business Permit Form -->
<section class="form-section" id="business-permit-section">
    <div class="section-header">
        <h2><i class="fas fa-briefcase"></i> Business Permit</h2>
        <button class="collapse-all-btn" data-target="business">
            <i class="fas fa-compress-alt"></i> Collapse All
        </button>
    </div>
    <form id="business-permit-form">
        <div class="form-group">
            <div class="form-group-header" data-toggle="business-info">
                <h3><i class="fas fa-building"></i> Business Information</h3>
                <i class="fas fa-chevron-down toggle-icon"></i>
            </div>
            <div class="form-group-content open" id="business-info">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="date_issued">Date Issued</label>
                        <input type="date" id="date_issued" name="date_issued" required>
                    </div>
                    <div class="form-field">
                        <label for="date_expiration">Expiration Date</label>
                        <input type="date" id="date_expiration" name="date_expiration" required>
                    </div>
                    <div class="form-field">
                        <label for="classification">Classification</label>
                        <input type="text" id="classification" name="classification" placeholder="NEW/RENEWAL" required>
                    </div>
                    <div class="form-field">
                        <label for="business_id_number">Business ID Number</label>
                        <input type="text" id="business_id_number" name="business_id_number" required>
                    </div>
                    <div class="form-field">
                        <label for="permit_number">Permit Number</label>
                        <input type="text" id="permit_number" name="permit_number">
                    </div>
                    <div class="form-field">
                        <label for="permit_year">Permit Year</label>
                        <input type="text" id="permit_year" name="permit_year" placeholder="2025" required>
                    </div>
                    <div class="form-field full-width">
                        <label for="business_name">Business Name</label>
                        <input type="text" id="business_name" name="business_name" required>
                    </div>
                </div>
            </div>
        </div>
        <button type="submit" class="submit-btn">
            <i class="fas fa-file-download"></i> Generate Permit
        </button>
    </form>
</section>
