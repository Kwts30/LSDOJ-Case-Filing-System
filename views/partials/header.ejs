<!-- Header Navigation -->
<header class="header">
  <div class="header-container">
    <!-- Brand -->
    <div class="header-brand">
      <img src="/assets/lossantos.webp" class="header-logo" alt="Los Santos">
      <img src="/assets/doj.png" class="header-logo" alt="Department of Justice">
      <div class="header-brand-text">
        <h1>Department of Justice</h1>
        <p>City of Los Santos | San Andreas</p>
      </div>
    </div>

    <!-- User Info & Actions -->
    <div class="header-actions">
      <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
        <div class="header-user-info">
          <div class="username"><%= typeof username !== 'undefined' ? username : 'User' %></div>
          <div class="role">
            <span class="material-icons role-icon">
              <%= (typeof userRole !== 'undefined' && userRole === 'admin') ? 'shield' : 'person' %>
            </span>
            <%= (typeof userRole !== 'undefined' && userRole === 'admin') ? 'Admin' : 'User' %>
          </div>
        </div>

        <div class="header-icon-group">
          <button type="button" class="header-icon-btn theme-toggle-btn" title="Toggle Theme">
            <span class="material-icons theme-toggle-icon">light_mode</span>
          </button>

          <a href="/auth/profile" class="header-icon-btn" title="Profile">
            <span class="material-icons">account_circle</span>
          </a>

          <% if (typeof userRole !== 'undefined' && userRole === 'admin') { %>
            <a href="/admin/dashboard" class="header-icon-btn" title="Admin Dashboard">
              <span class="material-icons">dashboard</span>
            </a>
          <% } %>

          <form action="/auth/logout" method="POST" class="form-inline">
            <button type="submit" class="header-icon-btn" title="Logout">
              <span class="material-icons">logout</span>
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</header>
