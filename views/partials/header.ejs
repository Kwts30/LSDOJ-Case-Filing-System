<!-- Header partial -->
<header class="header">
    <div class="header-container">
        <div class="header-brand">
            <img src="/assets/doj.png" class="header-logo" alt="Department of Justice Seal">
            <img src="/assets/lossantos.webp" class="header-logo" alt="City of Los Santos">
            <div class="header-text">
                <h1>DEPARTMENT OF JUSTICE</h1>
                <p>City of Los Santos | State of San Andreas</p>
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                <div style="color: white; font-size: 0.9rem;">
                    <span style="display: block; font-weight: 600;"><%= typeof username !== 'undefined' ? username : '' %></span>
                    <span style="opacity: 0.8;">
                        <i class="fas fa-circle" style="color: <%= (typeof userRole !== 'undefined' && userRole === 'admin') ? '#e74c3c' : '#2ecc71' %>; font-size: 0.6rem;"></i>
                        <%= (typeof userRole !== 'undefined' && userRole === 'admin') ? ' Admin' : ' User' %>
                    </span>
                </div>
            <% } %>
            <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle Menu">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </div>
    <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
        <div style="background: rgba(0,0,0,0.1); padding: 0.5rem 1.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="/auth/profile" style="color: white; text-decoration: none; font-size: 0.9rem;">
                <i class="fas fa-user-circle"></i> Profile
            </a>
            <% if (typeof userRole !== 'undefined' && userRole === 'admin') { %>
                <a href="/admin/dashboard" style="color: white; text-decoration: none; font-size: 0.9rem;">
                    <i class="fas fa-chart-line"></i> Admin
                </a>
            <% } %>
            <form action="/auth/logout" method="POST" style="display: inline;">
                <button type="submit" style="background: none; border: none; color: white; cursor: pointer; font-size: 0.9rem; padding: 0;">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    <% } %>
</header>
