<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="main-layout">
        <%- include('../partials/sidebar') %>
        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <div class="page-header-text">
                        <h1>
                            <span class="material-icons">group</span>
                            User Management
                        </h1>
                    </div>
                    <div class="page-header-actions">
                        <a href="/admin/users/add" class="btn btn-primary flex">
                            <span class="material-icons">add_circle</span>
                            Add User
                        </a>
                    </div>
                </div>

                <div class="card">
                    <div style="overflow-x:auto;">
                        <table class="table-clean">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (users && users.length) { %>
                                    <% users.forEach(u => { %>
                                        <tr>
                                            <td><%= u.username %></td>
                                            <td><%= u.email %></td>
                                            <td>
                                                <span class="badge badge-<%= u.role === 'admin' ? 'info' : 'success' %>">
                                                    <%= u.role %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge badge-<%= (u.is_active ?? u.isActive) ? 'success' : 'error' %>">
                                                    <%= (u.is_active ?? u.isActive) ? 'Active' : 'Inactive' %>
                                                </span>
                                            </td>
                                            <td><%= new Date(u.created_at || u.createdAt || Date.now()).toLocaleDateString() %></td>
                                            <td>
                                                <a href="/admin/users/<%= u._id %>" class="btn btn-secondary btn-sm">
                                                    <span class="material-icons" style="font-size:1rem;">edit</span>
                                                    Edit
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-tertiary" style="padding:var(--space-3xl);">
                                            <span class="material-icons" style="font-size:2rem;display:block;margin-bottom:var(--space-md);opacity:0.5;">person</span>
                                            No users found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
