<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Department of Justice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="main-layout">
        <%- include('../partials/sidebar') %>
        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <div class="page-header-text">
                        <h1>
                            <span class="material-icons">description</span>
                            Generated Documents
                        </h1>
                        <p>Total: <%= total %> &nbsp;·&nbsp; Page <%= page %> of <%= pages %></p>
                    </div>
                </div>

                <div class="card">
                    <div style="overflow-x:auto;">
                        <table class="table-clean">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Issuer</th>
                                    <th>Client</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% documents.forEach(doc => { %>
                                    <tr>
                                        <td><%= doc.doc_type || doc.documentType || '—' %></td>
                                        <td><%= doc.issuer_name || doc.issuerName || '—' %></td>
                                        <td><%= doc.client_name || doc.clientName || '—' %></td>
                                        <td><%= new Date(doc.created_at || doc.createdAt || Date.now()).toLocaleString() %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer flex" style="gap:var(--space-md);">
                        <% if (page > 1) { %>
                            <a href="?page=<%= page-1 %>" class="btn btn-secondary btn-sm">
                                <span class="material-icons" style="font-size:1rem;">chevron_left</span> Previous
                            </a>
                        <% } %>
                        <% if (page < pages) { %>
                            <a href="?page=<%= page+1 %>" class="btn btn-secondary btn-sm">
                                Next <span class="material-icons" style="font-size:1rem;">chevron_right</span>
                            </a>
                        <% } %>
                        <a href="/admin/dashboard" class="btn btn-outline btn-sm">
                            <span class="material-icons" style="font-size:1rem;">arrow_back</span> Back
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
