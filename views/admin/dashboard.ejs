<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="main-content">
  <div class="page-header">
    <div class="page-header-left">
      <h1>Admin Dashboard</h1>
      <p class="page-subtitle"><%= isSuperAdmin ? 'System-wide overview' : adminDept + ' department overview' %></p>
    </div>
    <div class="page-header-actions">
      <a href="/admin/export/report?type=filings" class="btn btn-ghost" title="Export Filings CSV">
        <span class="material-icons">download</span>
        Export Filings
      </a>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="stats-row">
    <div class="stat-card">
      <span class="material-icons stat-icon">group</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalUsers %></span>
        <span class="stat-label">Total Users</span>
      </div>
    </div>
    <div class="stat-card <%= stats.pendingAccounts > 0 ? 'stat-card--alert' : '' %>">
      <span class="material-icons stat-icon">how_to_reg</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.pendingAccounts %></span>
        <span class="stat-label">Pending Accounts</span>
      </div>
    </div>
    <div class="stat-card">
      <span class="material-icons stat-icon">folder</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalCases %></span>
        <span class="stat-label">Total Cases</span>
      </div>
    </div>
    <div class="stat-card <%= stats.escalatedCount > 0 ? 'stat-card--alert' : '' %>">
      <span class="material-icons stat-icon">warning</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.escalatedCount %></span>
        <span class="stat-label">Escalated</span>
      </div>
    </div>
    <div class="stat-card">
      <span class="material-icons stat-icon">speed</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.avgTurnaroundHours %>h</span>
        <span class="stat-label">Avg Turnaround</span>
      </div>
    </div>
  </div>

  <div class="dashboard-grid">
    <!-- Pending Account Signups -->
    <div class="dashboard-card">
      <div class="dashboard-card-header">
        <h2>Pending Account Verification</h2>
        <a href="/admin/accounts" class="btn btn-sm btn-ghost">View All</a>
      </div>
      <% const allPending = [...pendingLSPD, ...pendingDOJ]; %>
      <% if (allPending.length === 0) { %>
        <p class="empty-text">No pending accounts</p>
      <% } else { %>
        <div class="mini-table">
          <% allPending.slice(0, 5).forEach(u => { %>
            <div class="mini-table-row">
              <div class="mini-table-info">
                <span class="mini-table-primary"><%= u.username %> - <%= u.name %></span>
                <span class="mini-table-secondary"><%= u.department %> | <%= u.position %></span>
              </div>
              <div class="mini-table-actions">
                <button class="btn btn-sm btn-success approve-account-btn" data-id="<%= u._id %>">
                  Approve
                </button>
                <button class="btn btn-sm btn-danger reject-account-btn" data-id="<%= u._id %>">
                  Reject
                </button>
              </div>
            </div>
          <% }); %>
          <% if (allPending.length > 5) { %>
            <p class="mini-table-more"><a href="/admin/accounts">+<%= allPending.length - 5 %> more</a></p>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Case Status Breakdown -->
    <div class="dashboard-card">
      <div class="dashboard-card-header">
        <h2>Case Status Breakdown</h2>
      </div>
      <div class="status-breakdown">
        <% caseStatusCounts.forEach(s => { %>
          <% const display = STATUS_DISPLAY[s._id] || { label: s._id, color: 'status-draft' }; %>
          <div class="status-row">
            <span class="status-badge status-<%= s._id %>"><%= display.label %></span>
            <span class="status-count"><%= s.count %></span>
          </div>
        <% }); %>
        <% if (caseStatusCounts.length === 0) { %>
          <p class="empty-text">No cases yet</p>
        <% } %>
      </div>
    </div>

    <!-- Escalated Filings -->
    <% if (escalatedCases.length > 0) { %>
      <div class="dashboard-card dashboard-card--alert">
        <div class="dashboard-card-header">
          <h2>Escalated Filings</h2>
          <span class="badge badge-danger"><%= escalatedCases.length %></span>
        </div>
        <div class="mini-table">
          <% escalatedCases.slice(0, 5).forEach(c => { %>
            <div class="mini-table-row">
              <div class="mini-table-info">
                <span class="mini-table-primary"><%= c.filing_number %> - <%= c.accused_name %></span>
                <span class="mini-table-secondary">
                  Status: <%= c.status.replace(/_/g, ' ') %> |
                  Age: <%= Math.round((Date.now() - new Date(c.created_at).getTime()) / (1000 * 60 * 60)) %>h
                </span>
              </div>
              <a href="/da-review/<%= c.filing_number %>" class="btn btn-sm btn-ghost">View</a>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Recent Activity -->
    <div class="dashboard-card dashboard-card--wide">
      <div class="dashboard-card-header">
        <h2>Recent Activity</h2>
        <a href="/admin/audit-log" class="btn btn-sm btn-ghost">Full Log</a>
      </div>
      <% if (recentActivity.length === 0) { %>
        <p class="empty-text">No recent activity</p>
      <% } else { %>
        <div class="activity-list">
          <% recentActivity.forEach(log => { %>
            <div class="activity-item">
              <span class="material-icons activity-icon">
                <%
                  const iconMap = {
                    login: 'login', logout: 'logout', signup: 'person_add',
                    create: 'add_circle', edit: 'edit', view: 'visibility',
                    approve: 'check_circle', deny: 'cancel', submit: 'send',
                    claim: 'assignment_ind', generate: 'auto_fix_high',
                    delete: 'delete', revise: 'assignment_return', close: 'lock',
                    download: 'download'
                  };
                %>
                <%= iconMap[log.action] || 'radio_button_checked' %>
              </span>
              <div class="activity-info">
                <span class="activity-actor">
                  <% if (actorMap[log.actor?.toString()]) { %>
                    <%= actorMap[log.actor.toString()].name %>
                  <% } else { %>
                    System
                  <% } %>
                </span>
                <span class="activity-action"><%= log.action %></span>
                <span class="activity-details"><%= log.details %></span>
              </div>
              <span class="activity-time"><%= log.timestamp ? new Date(log.timestamp).toLocaleString() : '' %></span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</main>

<script>
  // Quick approve/reject from dashboard
  document.querySelectorAll('.approve-account-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      try {
        const res = await fetch('/admin/accounts/' + btn.dataset.id + '/approve', { method: 'POST' });
        const result = await res.json();
        if (result.success) location.reload();
        else { alert(result.error); btn.disabled = false; }
      } catch { alert('Failed to approve'); btn.disabled = false; }
    });
  });

  document.querySelectorAll('.reject-account-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const reason = prompt('Enter rejection reason:');
      if (!reason) return;
      btn.disabled = true;
      try {
        const res = await fetch('/admin/accounts/' + btn.dataset.id + '/reject', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ rejection_reason: reason })
        });
        const result = await res.json();
        if (result.success) location.reload();
        else { alert(result.error); btn.disabled = false; }
      } catch { alert('Failed to reject'); btn.disabled = false; }
    });
  });
</script>

<%- include('../partials/footer') %>
