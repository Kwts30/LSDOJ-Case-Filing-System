<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
        .stat-card { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .stat-card h3 { color: #666; font-size: 0.9rem; margin-bottom: 0.5rem; }
        .stat-number { font-size: 2.5rem; font-weight: 700; color: #6b3a0b; }
        .admin-container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
        .section { margin-bottom: 3rem; }
        .section h2 { color: #6b3a0b; margin-bottom: 1rem; border-bottom: 2px solid #e0e0e0; padding-bottom: 0.5rem; }
        table { width: 100%; border-collapse: collapse; background: white; }
        th { background: #f9f9f9; padding: 1rem; text-align: left; font-weight: 600; color: #666; border-bottom: 2px solid #e0e0e0; }
        td { padding: 1rem; border-bottom: 1px solid #e0e0e0; }
        .btn { padding: 0.5rem 1rem; background: #6b3a0b; color: white; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; display: inline-block; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    <div class="admin-container">
        <h1><i class="fas fa-chart-line"></i> Admin Dashboard</h1>
        
        <div class="dashboard-grid">
            <div class="stat-card">
                <h3>Total Users</h3>
                <div class="stat-number"><%= stats.totalUsers %></div>
            </div>
            <div class="stat-card">
                <h3>Active Users</h3>
                <div class="stat-number"><%= stats.activeUsers %></div>
            </div>
            <div class="stat-card">
                <h3>Generated Documents</h3>
                <div class="stat-number"><%= stats.totalDocuments %></div>
            </div>
            <div class="stat-card">
                <h3>Activity Logs</h3>
                <div class="stat-number"><%= stats.totalLogs %></div>
            </div>
        </div>

        <div class="section">
            <h2>Documents by Type</h2>
            <table>
                <tr><th>Document Type</th><th>Count</th></tr>
                <% documentsByType.forEach(doc => { %>
                    <tr><td><%= doc._id %></td><td><%= doc.count %></td></tr>
                <% }); %>
            </table>
        </div>

        <div class="section">
            <h2>Quick Links</h2>
            <a href="/admin/documents" class="btn"><i class="fas fa-file"></i> View Documents</a>
            <a href="/admin/activity-logs" class="btn"><i class="fas fa-list"></i> Activity Logs</a>
            <a href="/admin/reports" class="btn"><i class="fas fa-chart-bar"></i> Reports</a>
            <a href="/admin/users" class="btn"><i class="fas fa-users"></i> Manage Users</a>
        </div>

        <div style="margin-top: 3rem;">
            <a href="/" class="btn"><i class="fas fa-arrow-left"></i> Back to App</a>
        </div>
    </div>
</body>
</html>
