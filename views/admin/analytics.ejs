<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="main-content">
  <div class="page-header">
    <div class="page-header-left">
      <h1>Analytics</h1>
      <p class="page-subtitle">System performance and usage metrics</p>
    </div>
  </div>

  <!-- Overview Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <span class="material-icons stat-icon">folder</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalCases %></span>
        <span class="stat-label">Total Filings</span>
      </div>
    </div>
    <div class="stat-card">
      <span class="material-icons stat-icon">group</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.totalUsers %></span>
        <span class="stat-label">Total Users</span>
      </div>
    </div>
    <div class="stat-card">
      <span class="material-icons stat-icon">check_circle</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.activeUsers %></span>
        <span class="stat-label">Active Users</span>
      </div>
    </div>
    <div class="stat-card">
      <span class="material-icons stat-icon">login</span>
      <div class="stat-content">
        <span class="stat-value"><%= stats.recentLogins %></span>
        <span class="stat-label">Total Logins</span>
      </div>
    </div>
  </div>

  <div class="dashboard-grid">
    <!-- Case Status Distribution -->
    <div class="dashboard-card">
      <div class="dashboard-card-header">
        <h2>Filing Status Distribution</h2>
      </div>
      <div class="chart-placeholder">
        <div class="bar-chart">
          <% casesByStatus.forEach(s => { %>
            <% const display = STATUS_DISPLAY[s._id] || { label: s._id, color: 'status-draft' }; %>
            <div class="bar-row">
              <span class="bar-label"><%= display.label %></span>
              <div class="bar-track">
                <div class="bar-fill status-<%= s._id %>" style="width: <%= stats.totalCases > 0 ? Math.round((s.count / stats.totalCases) * 100) : 0 %>%"></div>
              </div>
              <span class="bar-value"><%= s.count %></span>
            </div>
          <% }); %>
          <% if (casesByStatus.length === 0) { %>
            <p class="empty-text">No filing data yet</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Top Filing Officers -->
    <div class="dashboard-card">
      <div class="dashboard-card-header">
        <h2>Top Filing Officers</h2>
      </div>
      <% if (casesByOfficer.length === 0) { %>
        <p class="empty-text">No filings yet</p>
      <% } else { %>
        <div class="leaderboard">
          <% casesByOfficer.forEach((item, idx) => { %>
            <div class="leaderboard-row">
              <span class="leaderboard-rank"><%= idx + 1 %></span>
              <div class="leaderboard-info">
                <% if (userMap[item._id?.toString()]) { %>
                  <span class="leaderboard-name"><%= userMap[item._id.toString()].name %></span>
                  <span class="leaderboard-meta"><%= userMap[item._id.toString()].username %> | <%= userMap[item._id.toString()].position %></span>
                <% } else { %>
                  <span class="leaderboard-name">Unknown</span>
                <% } %>
              </div>
              <span class="leaderboard-count"><%= item.count %> filings</span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Top Reviewers -->
    <div class="dashboard-card">
      <div class="dashboard-card-header">
        <h2>Top DA Reviewers</h2>
      </div>
      <% if (reviewsByReviewer.length === 0) { %>
        <p class="empty-text">No reviews yet</p>
      <% } else { %>
        <div class="leaderboard">
          <% reviewsByReviewer.forEach((item, idx) => { %>
            <div class="leaderboard-row">
              <span class="leaderboard-rank"><%= idx + 1 %></span>
              <div class="leaderboard-info">
                <% if (userMap[item._id?.toString()]) { %>
                  <span class="leaderboard-name"><%= userMap[item._id.toString()].name %></span>
                  <span class="leaderboard-meta"><%= userMap[item._id.toString()].username %> | <%= userMap[item._id.toString()].position %></span>
                <% } else { %>
                  <span class="leaderboard-name">Unknown</span>
                <% } %>
              </div>
              <span class="leaderboard-count"><%= item.count %> reviews</span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
