<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Department of Justice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="main-layout">
        <%- include('../partials/sidebar') %>
        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <div class="page-header-text">
                        <h1>
                            <span class="material-icons">bar_chart</span>
                            User Analytics
                        </h1>
                        <p>System-wide usage statistics</p>
                    </div>
                </div>

                <!-- Stat Cards -->
                <div class="grid grid-2 mb-xl">
                    <div class="card stat-card">
                        <div class="card-body">
                            <span class="material-icons stat-icon" style="color:var(--color-secondary);">login</span>
                            <span class="stat-value"><%= analytics.logins %></span>
                            <span class="stat-label">Total Logins</span>
                        </div>
                    </div>
                    <div class="card stat-card">
                        <div class="card-body">
                            <span class="material-icons stat-icon" style="color:var(--color-primary);">description</span>
                            <span class="stat-value"><%= analytics.documentCreations %></span>
                            <span class="stat-label">Documents Generated</span>
                        </div>
                    </div>
                </div>

                <!-- Top Users Table -->
                <div class="card">
                    <div class="card-header flex">
                        <span class="material-icons">leaderboard</span>
                        <h3 style="margin:0;">User Activity (Top Users)</h3>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="table-clean">
                            <thead>
                                <tr>
                                    <th>User ID</th>
                                    <th>Total Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% analytics.userActivity.forEach(user => { %>
                                    <tr>
                                        <td><%= user._id %></td>
                                        <td><strong><%= user.actions %></strong></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/dashboard" class="btn btn-outline btn-sm">
                            <span class="material-icons" style="font-size:1rem;">arrow_back</span> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
