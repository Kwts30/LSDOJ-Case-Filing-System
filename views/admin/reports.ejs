<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Department of Justice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="main-layout">
        <%- include('../partials/sidebar') %>
        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <div class="page-header-text">
                        <h1>
                            <span class="material-icons">summarize</span>
                            Reports
                        </h1>
                        <p>Document issuance statistics</p>
                    </div>
                </div>

                <!-- Documents by Type -->
                <div class="card mb-xl">
                    <div class="card-header flex">
                        <span class="material-icons">pie_chart</span>
                        <h3 style="margin:0;">Documents by Type</h3>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="table-clean">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% reports.byType.forEach(r => { %>
                                    <tr>
                                        <td><%= r._id %></td>
                                        <td><strong><%= r.count %></strong></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/export/report?type=documents" class="btn btn-secondary btn-sm">
                            <span class="material-icons" style="font-size:1rem;">download</span> Export CSV
                        </a>
                    </div>
                </div>

                <!-- Documents by User -->
                <div class="card">
                    <div class="card-header flex">
                        <span class="material-icons">person</span>
                        <h3 style="margin:0;">Documents by User</h3>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="table-clean">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% reports.byUser.forEach(r => { %>
                                    <tr>
                                        <td><%= r.clientName || r._id %></td>
                                        <td><strong><%= r.count %></strong></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/dashboard" class="btn btn-outline btn-sm">
                            <span class="material-icons" style="font-size:1rem;">arrow_back</span> Back
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
