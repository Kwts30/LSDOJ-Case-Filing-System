<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Department of Justice
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
    <style>
        .page-header-flex {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.75rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-title {
            font-size: 1.6rem;
            font-weight: 800;
            margin: 0;
            color: var(--color-text-primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-title .material-icons {
            font-size: 1.8rem;
            color: var(--color-secondary);
        }

        .page-sub {
            margin: 0.25rem 0 0;
            font-size: 0.85rem;
            color: var(--color-text-tertiary);
        }

        .content-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            align-items: start;
        }

        @media (max-width: 992px) {
            .content-grid-2 {
                grid-template-columns: 1fr;
            }
        }

        .panel {
            background: var(--color-bg-primary);
            border: 1px solid var(--color-border);
            border-radius: 14px;
            overflow: hidden;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--color-border);
            background: var(--color-bg-secondary);
        }

        .panel-title {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--color-text-primary);
        }

        .panel-title .material-icons {
            font-size: 1.1rem;
            color: var(--color-secondary);
        }

        .preview-sticky {
            position: sticky;
            top: var(--space-lg);
        }

        .export-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--color-border);
            background: var(--color-bg-secondary);
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .export-format-group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .export-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--color-text-secondary);
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .export-select {
            padding: 0.35rem 0.75rem;
            border: 1px solid var(--color-border);
            border-radius: 7px;
            background: var(--color-bg-primary);
            color: var(--color-text-primary);
            font-family: inherit;
            font-size: 0.82rem;
            outline: none;
        }

        .export-actions {
            display: flex;
            gap: 0.4rem;
        }

        .export-btn {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.35rem 0.75rem;
            font-size: 0.82rem;
        }

        .export-btn .material-icons {
            font-size: 1rem;
        }

        #preview-container {
            padding: 1.5rem;
            background: var(--color-bg-tertiary);
            display: flex;
            justify-content: center;
            min-height: 400px;
        }

        #preview-canvas {
            max-width: 100%;
            height: auto;
            border: 1px solid var(--color-border);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border-radius: 4px;
        }

        .form-section {
            display: none !important;
        }

        .form-section.active {
            display: block !important;
        }

        .nav-tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--color-border);
            padding-bottom: 0.75rem;
            flex-wrap: wrap;
        }

        .nav-item.btn-outline {
            border-color: transparent;
            color: var(--color-text-secondary);
        }

        .nav-item.btn-outline:hover {
            border-color: var(--color-border);
            background: var(--color-bg-secondary);
        }

        .nav-item.active, .nav-item.active:hover {
            background: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }
    </style>
</head>

<body
    class="<%= (typeof currentPage !== 'undefined' && currentPage === 'create-document') ? 'page-create-document' : '' %>">
    <%- include('partials/header') %>

        <div class="main-layout">
            <%- include('partials/sidebar') %>

                <main class="main-content">
                    <div class="container" style="max-width: 1400px;">

                        <div class="page-header-flex">
                            <div>
                                <h1 class="page-title">
                                    <span class="material-icons">note_add</span>
                                    Create Document
                                </h1>
                                <p class="page-sub">Fill out the forms below to generate an official document</p>
                            </div>
                        </div>

                        <div>

                            <!-- Navigation Tabs -->
                            <div class="nav-tabs">
                                <button class="nav-item btn btn-outline active" data-section="requestforwarrant">
                                    <span class="material-icons" style="font-size:1.1rem">article</span> Request for Warrant
                                </button>
                                <button class="nav-item btn btn-outline" data-section="affidavitofcomplaint">
                                    <span class="material-icons" style="font-size:1.1rem">gavel</span> Affidavit of Complaint
                                </button>
                            </div>

                            <!-- Form Section -->
                            <div class="panel">
                                <div class="panel-header">
                                    <div class="panel-title">
                                        <span class="material-icons">edit_document</span>
                                        Document Details
                                    </div>
                                </div>
                                <div class="form-panel"
                                    style="padding: 1.5rem; border: none; background: transparent; box-shadow: none;">
                                    <%- include('partials/forms/requestforwarrant') %>
                                    <%- include('partials/forms/affidavitofcomplaint') %>
                                </div>
                            </div>

                        </div>

                    </div>
                </main>
        </div>

        <%- include('partials/overlay') %>
            <%- include('partials/footer') %>
                <%- include('partials/modals') %>

                     <!-- PDF and HTML Rendering Libraries -->
                     <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
                     <script>pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';</script>
                     <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
                     <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
                     <script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
 
                     <!-- Modular JavaScript -->
                     <script src="/js/form-utils.js"></script>
                     <script src="/js/document-handlers.js"></script>
                     <script src="/js/app.js?v=13"></script>
<%- include('partials/cookie-banner') %>
</body>

</html>

</html>