<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/theme.js"></script>
</head>
<body style="
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg);
">
    <div class="card" style="max-width: 500px; text-align: center; padding: var(--space-4xl) var(--space-2xl);">
        <span class="material-icons" style="font-size: 5rem; color: var(--color-error); display: block; margin-bottom: var(--space-lg);">error_outline</span>

        <h1 style="font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--space-md);">
          Error <%= typeof statusCode !== 'undefined' ? statusCode : '500' %>
        </h1>

        <p style="color: var(--color-text-secondary); font-size: var(--font-size-lg); margin-bottom: var(--space-lg);">
          <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred' %>
        </p>

        <% if (typeof details !== 'undefined' && details) { %>
          <div style="
            background: var(--color-error-light);
            border: 1px solid var(--color-error);
            color: var(--color-error-dark);
            padding: var(--space-lg);
            border-radius: var(--radius-md);
            margin-bottom: var(--space-lg);
            font-size: var(--font-size-sm);
            text-align: left;
          ">
            <strong>Details:</strong><br>
            <%= details %>
          </div>
        <% } %>

        <div style="display: flex; gap: var(--space-md); justify-content: center;">
          <a href="/" class="btn btn-secondary">
            <span class="material-icons" style="display: inline; margin-right: var(--space-sm);">home</span>
            Back to Dashboard
          </a>
          <button onclick="window.history.back();" class="btn btn-outline">
            <span class="material-icons" style="display: inline; margin-right: var(--space-sm);">arrow_back</span>
            Go Back
          </button>
        </div>
    </div>


</body>
</html>
