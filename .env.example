NODE_ENV=development
PORT=3000

# Required for production. Use a private MongoDB deployment and strong random secrets.
MONGODB_URI=mongodb://127.0.0.1:27017/doj-case-filing
SESSION_SECRET=replace-with-a-long-random-session-secret
JWT_SECRET=replace-with-a-long-random-jwt-secret
ADMIN_USERNAME=ADMIN-001
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@example.invalid

# Optional runtime settings
TRUST_PROXY=false
SESSION_COOKIE_NAME=filing.sid
SESSION_SAME_SITE=lax
SESSION_MAX_AGE_MS=3600000
PASSWORD_MIN_LENGTH=12
RATE_LIMIT_MAX_REQUESTS=50
FILING_SEQUENCE_RETRY_LIMIT=100
ESCALATION_THRESHOLD_HOURS=48
CRON_TIMEZONE=Asia/Manila

# Optional DOCX → PDF/PNG rendering. Install LibreOffice and set its soffice.exe path.
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# WINWORD_PATH=C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE
# DOCUMENT_RENDER_DPI=150
# DOCUMENT_RENDER_TIMEOUT_MS=120000
